<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE bulletml PUBLIC "-//Nakamura//DTD BulletML 1.0//EN" "http://www.dan-ball.jp/bulletml/bulletml.dtd">
<bulletml type="vertical" xmlns="http://www.asahi-net.or.jp/~cs8k-cyu/bulletml">
  <bullet label="DefaultBullet">
    <direction type="absolute">0</direction>
    <speed type="absolute">0</speed>
  </bullet>
  <action label="Top">
    <fireRef label="Straight Up Fire">
    </fireRef>
    <wait>15</wait>
    <actionRef label="Sideways Action">
    </actionRef>
    <wait>1</wait>
  </action>
  <action label="Sideways Action">
    <fireRef label="Angle Fire">
    </fireRef>
    <wait>60</wait>
  </action>
  <fire label="Straight Up Fire">
    <direction type="absolute">0</direction>
    <speed type="absolute">1</speed>
    <bulletRef label="DefaultBullet">
    </bulletRef>
  </fire>
  <fire label="Angle Fire">
    <direction type="relative">90</direction>
    <speed type="absolute">1</speed>
    <bulletRef label="DefaultBullet">
    </bulletRef>
  </fire>
</bulletml>
