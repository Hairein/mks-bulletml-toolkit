<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE bulletml PUBLIC "-//Nakamura//DTD BulletML 1.0//EN" "http://www.dan-ball.jp/bulletml/bulletml.dtd">
<bulletml type="horizontal" xmlns="http://www.asahi-net.or.jp/~cs8k-cyu/bulletml">
  <action label="top">
    <actionRef label="second">
      <param>0.15 + ($rand * 0.85)</param>
    </actionRef>
  </action>
  <action label="second">
    <fireRef label="fire">
      <param>$rand * 360</param>
      <param>$1</param>
    </fireRef>
    <wait>30</wait>
  </action>
  <fire label="fire">
    <direction type="absolute">$1</direction>
    <speed type="absolute">$2</speed>
    <bulletRef label="bullet">
    </bulletRef>
  </fire>
  <bullet label="bullet">
    <direction type="absolute">0.0</direction>
    <speed type="absolute">0.0</speed>
  </bullet>
</bulletml>
