<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE bulletml PUBLIC "-//Nakamura//DTD BulletML 1.0//EN" "http://www.dan-ball.jp/bulletml/bulletml.dtd">
<bulletml type="vertical" xmlns="http://www.asahi-net.or.jp/~cs8k-cyu/bulletml">
  <bullet label="default">
    <direction type="absolute">0</direction>
    <speed type="absolute">0</speed>
  </bullet>
  <action label="top">
    <actionRef label="do aim fire">
    </actionRef>
  </action>
  <action label="sub">
    <fireRef label="stable">
    </fireRef>
    <wait>15</wait>
  </action>
  <action label="do aim fire">
    <fireRef label="Aimed Fire">
    </fireRef>
    <wait>15</wait>
  </action>
  <fire label="stable">
    <direction type="absolute">0</direction>
    <speed type="absolute">1</speed>
    <bulletRef label="default">
    </bulletRef>
  </fire>
  <fire label="Aimed Fire">
    <direction type="aim">0</direction>
    <speed type="absolute">2.5</speed>
    <bulletRef label="default">
    </bulletRef>
  </fire>
</bulletml>
