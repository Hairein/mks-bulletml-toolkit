<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE bulletml PUBLIC "-//Nakamura//DTD BulletML 1.0//EN" "http://www.dan-ball.jp/bulletml/bulletml.dtd">
<bulletml type="vertical" xmlns="http://www.asahi-net.or.jp/~cs8k-cyu/bulletml">
  <action label="top">
    <fireRef label="fire start">
    </fireRef>
    <wait>60</wait>
  </action>
  <action label="fireworks">
    <repeat>
      <times>15</times>
      <actionRef label="secondary">
      </actionRef>
    </repeat>
  </action>
  <action label="secondary">
    <wait>60</wait>
    <fireRef label="fire end">
    </fireRef>
  </action>
  <fire label="fire start">
    <direction type="relative">0.0</direction>
    <speed type="relative">0.0</speed>
    <bulletRef label="bullet start">
    </bulletRef>
  </fire>
  <fire label="fire end">
    <direction type="relative">$rand * 360.0</direction>
    <speed type="relative">($rand * 1.5)</speed>
    <bulletRef label="bullet end">
    </bulletRef>
  </fire>
  <bullet label="bullet start">
    <direction type="absolute">$rand * 360.0</direction>
    <speed type="absolute">0.5 + ($rand * 1.5)</speed>
    <actionRef label="fireworks">
    </actionRef>
  </bullet>
  <bullet label="bullet end">
    <direction type="relative">0.0</direction>
    <speed type="relative">0.25</speed>
  </bullet>
</bulletml>
