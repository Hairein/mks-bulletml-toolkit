<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE bulletml PUBLIC "-//Nakamura//DTD BulletML 1.0//EN" "http://www.dan-ball.jp/bulletml/bulletml.dtd">
<bulletml type="horizontal" xmlns="http://www.asahi-net.or.jp/~cs8k-cyu/bulletml">
  <action label="top">
    <fireRef label="fire">
      <param>45</param>
      <param>0.25</param>
    </fireRef>
    <wait>30</wait>
    <actionRef label="second">
      <param>-45</param>
      <param>0.25</param>
    </actionRef>
    <wait>15</wait>
  </action>
  <action label="second">
    <fireRef label="fire2">
      <param>45</param>
      <param>0.5</param>
    </fireRef>
    <wait>15</wait>
  </action>
  <fire label="fire">
    <direction type="relative">$1</direction>
    <speed type="relative">$2</speed>
    <bulletRef label="bullet">
      <param>45</param>
      <param>0.35</param>
    </bulletRef>
  </fire>
  <fire label="fire2">
    <direction type="relative">$1</direction>
    <speed type="relative">$2</speed>
    <bulletRef label="bullet2">
    </bulletRef>
  </fire>
  <bullet label="bullet">
    <direction type="absolute">$1</direction>
    <speed type="absolute">$2</speed>
  </bullet>
  <bullet label="bullet2">
    <direction type="absolute">0</direction>
    <speed type="absolute">1.0</speed>
  </bullet>
</bulletml>
