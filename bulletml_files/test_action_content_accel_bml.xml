<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE bulletml PUBLIC "-//Nakamura//DTD BulletML 1.0//EN" "http://www.dan-ball.jp/bulletml/bulletml.dtd">
<bulletml type="horizontal" xmlns="http://www.asahi-net.or.jp/~cs8k-cyu/bulletml">
  <action label="top">
    <fireRef label="fire">
    </fireRef>
    <accel>
      <horizontal type="sequence">50</horizontal>
      <vertical type="sequence">0</vertical>
      <term>60</term>
    </accel>
    <wait>15</wait>
  </action>
  <fire label="fire">
    <direction type="absolute">90</direction>
    <speed type="absolute">0.5</speed>
    <bulletRef label="bullet">
    </bulletRef>
  </fire>
  <bullet label="bullet">
    <direction type="absolute">0.0</direction>
    <speed type="absolute">0.0</speed>
  </bullet>
</bulletml>
