<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE bulletml PUBLIC "-//Nakamura//DTD BulletML 1.0//EN" "http://www.dan-ball.jp/bulletml/bulletml.dtd">
<bulletml type="horizontal" xmlns="http://www.asahi-net.or.jp/~cs8k-cyu/bulletml">
  <action label="top">
    <fireRef label="fire">
    </fireRef>
    <wait>60</wait>
  </action>
  <action label="side">
    <wait>30</wait>
    <fireRef label="side_fire">
    </fireRef>
  </action>
  <fire label="fire">
    <direction type="absolute">0.0</direction>
    <speed type="absolute">1.0</speed>
    <bulletRef label="bullet1">
    </bulletRef>
  </fire>
  <fire label="side_fire">
    <direction type="relative">90.0</direction>
    <speed type="absolute">1.0</speed>
    <bulletRef label="bullet2">
    </bulletRef>
  </fire>
  <bullet label="bullet1">
    <direction type="absolute">0.0</direction>
    <speed type="absolute">1.0</speed>
    <actionRef label="side">
    </actionRef>
  </bullet>
  <bullet label="bullet2">
    <direction type="absolute">0.0</direction>
    <speed type="absolute">1.0</speed>
  </bullet>
</bulletml>
