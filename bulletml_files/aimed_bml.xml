<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE bulletml PUBLIC "-//Nakamura//DTD BulletML 1.0//EN" "http://www.dan-ball.jp/bulletml/bulletml.dtd">
<bulletml type="horizontal" xmlns="http://www.asahi-net.or.jp/~cs8k-cyu/bulletml">
  <action label="top">
    <repeat>
      <times>15</times>
      <actionRef label="spray">
      </actionRef>
    </repeat>
    <wait>15</wait>
  </action>
  <action label="spray">
    <fireRef label="aimed fire">
    </fireRef>
  </action>
  <fire label="aimed fire">
    <direction type="relative">0.0</direction>
    <speed type="relative">0.0</speed>
    <bulletRef label="new aimed bullet">
    </bulletRef>
  </fire>
  <bullet label="new aimed bullet">
    <direction type="aim">-10.0 + ($rand * 20.0)</direction>
    <speed type="absolute">0.25 + ($rand * 1.5)</speed>
  </bullet>
</bulletml>
