<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE bulletml PUBLIC "-//Nakamura//DTD BulletML 1.0//EN" "http://www.dan-ball.jp/bulletml/bulletml.dtd">
<bulletml type="vertical" xmlns="http://www.asahi-net.or.jp/~cs8k-cyu/bulletml">
  <action label="top">
    <repeat>
      <times>15</times>
      <actionRef label="emit">
      </actionRef>
    </repeat>
    <wait>30</wait>
  </action>
  <action label="emit">
    <fireRef label="fire down">
    </fireRef>
    <wait>5</wait>
  </action>
  <action label="trigger">
    <fireRef label="fire">
    </fireRef>
    <wait>30</wait>
  </action>
  <fire label="fire">
    <direction type="absolute">-45 + (90 * $rand)</direction>
    <speed type="absolute">1.0</speed>
    <bulletRef label="bullet">
    </bulletRef>
  </fire>
  <fire label="fire down">
    <direction type="absolute">-90 + (180 * $rand)</direction>
    <speed type="absolute">-0.5 - ($rand * 1.0)</speed>
    <bulletRef label="bullet2">
    </bulletRef>
  </fire>
  <bullet label="bullet">
    <direction type="absolute">0.0</direction>
    <speed type="absolute">1.0</speed>
  </bullet>
  <bullet label="bullet2">
    <direction type="absolute">0.0</direction>
    <speed type="absolute">1.0</speed>
  </bullet>
</bulletml>
